<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wisdom Wins</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-600 text-white min-h-screen flex items-center justify-center p-4">
    <div class="max-w-sm w-full bg-white text-green-800 rounded-3xl shadow-xl p-8 text-center">
        <h1 class="text-4xl font-bold mb-2">Grok Wins Counter</h1>
        <p class="text-green-600 mb-8">For Wisdom in Abuja 🇳🇬</p>
        
        <div id="count" class="text-9xl font-black mb-8">0</div>
        
        <div class="flex gap-4 justify-center mb-8">
            <button onclick="decrement()" 
                    class="w-20 h-20 bg-gray-200 hover:bg-gray-300 rounded-2xl text-5xl font-light transition">−</button>
            <button onclick="increment()" 
                    class="w-20 h-20 bg-green-600 hover:bg-green-700 text-white rounded-2xl text-5xl font-light transition">+</button>
        </div>
        
        <button onclick="reset()" 
                class="w-full py-4 bg-gray-100 hover:bg-gray-200 rounded-2xl text-lg font-medium transition">
            Reset to 0
        </button>
        
        <p class="mt-8 text-xs text-gray-500">Your daily wins • Built live for you</p>
    </div>

    <script>
        let count = 0;
        const countEl = document.getElementById('count');

        function increment() {
            count++;
            countEl.textContent = count;
        }
        function decrement() {
            if (count > 0) {
                count--;
                countEl.textContent = count;
            }
        }
        function reset() {
            count = 0;
            countEl.textContent = count;
        }
    </script>
</body>
</html>
